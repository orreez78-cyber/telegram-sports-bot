# Скопируйте этот файл в .env и заполните значениями.
# Файл .env не должен попадать в систему контроля версий (см. .gitignore).

# Telegram Bot API (обязательно)
TELEGRAM_TOKEN=

# OpenAI (необязательно: без ключа используется резервное объяснение)
OPENAI_API_KEY=

# Спортивные данные
FOOTBALL_API_KEY=
FOOTBALL_DATA_ORG_KEY=
PANDASCORE_API_KEY=
THE_ODDS_API_KEY=
HOCKEY_API_KEY=
HOCKEY_API_SPORTS=

# Необязательные параметры
# MAX_LIVE_FOOTBALL=2
