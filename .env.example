# Copy to .env and fill in. Never commit the real .env (it is gitignored).
# Rotate any key that was previously committed to git history.

# --- Required ---
TELEGRAM_TOKEN=            # BotFather token; the bot refuses to start without it

# --- Optional (features degrade gracefully if unset) ---
OPENAI_API_KEY=           # AI explanations; falls back to rule-based text if empty
FOOTBALL_API_KEY=         # API-Football (api-sports.io) fixtures/results
FOOTBALL_DATA_ORG_KEY=    # football-data.org
PANDASCORE_API_KEY=       # PandaScore (esports)
THE_ODDS_API_KEY=         # The Odds API (bookmaker odds -> value betting)
HOCKEY_API_KEY=           # Hockey data provider
HOCKEY_API_SPORTS=        # Hockey (api-sports.io)
